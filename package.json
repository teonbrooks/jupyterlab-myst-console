{
  "name": "jupyterlab-myst-console",
  "version": "0.1.0",
  "description": "MyST Markdown syntax highlighting and code console for JupyterLab",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "myst",
    "markdown"
  ],
  "homepage": "https://github.com/teonbrooks/jupyterlab-myst-console",
  "bugs": {
    "url": "https://github.com/teonbrooks/jupyterlab-myst-console/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Teon L Brooks",
    "email": "teon.brooks@gmail.com"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "styleModule": "style/index.js",
  "files": [
    "lib/**/*.{d.ts,js,js.map}",
    "style/**/*.{css,js,svg}",
    "schema/**/*.json"
  ],
  "scripts": {
    "build": "jlpm run build:lib && jlpm run build:labextension:dev",
    "build:prod": "jlpm run clean && jlpm run build:lib:prod && jlpm run build:labextension",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "clean": "jlpm run clean:lib && jlpm run clean:labextension",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:labextension": "rimraf jupyterlab_myst_console/labextension",
    "install:extension": "jlpm run build",
    "lint": "jlpm eslint . && jlpm prettier --check \"**/*{.ts,.tsx}\"",
    "lint:fix": "jlpm eslint --fix . && jlpm prettier --write \"**/*{.ts,.tsx}\"",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/language": "^6.10.1",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.1",
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/codemirror": "^4.0.0",
    "@jupyterlab/console": "^4.0.0",
    "@jupyterlab/docmanager": "^4.5.6",
    "@jupyterlab/docregistry": "^4.0.0",
    "@jupyterlab/fileeditor": "^4.0.0",
    "@jupyterlab/launcher": "^4.5.6",
    "@jupyterlab/rendermime": "^4.0.0",
    "@jupyterlab/services": "^7.0.0",
    "@jupyterlab/settingregistry": "^4.0.0",
    "@jupyterlab/ui-components": "^4.0.0",
    "@lezer/highlight": "^1.2.0",
    "@lezer/markdown": "^1.3.2"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^6.1.0",
    "@typescript-eslint/parser": "^6.1.0",
    "eslint": "^8.36.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.1",
    "typescript": "~5.0.2"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "jupyterlab_myst_console/labextension",
    "schemaDir": "schema"
  }
}
